{
  "numpy_version": "2.4.5",
  "fixture_schema_version": 2,
  "function": "numpy.add",
  "ferray_function": "ferray_ufunc::add_datetime_timedelta",
  "test_cases": [
    {
      "name": "same_unit_days",
      "inputs": {
        "a": {
          "data": [
            18262,
            -9223372036854775808,
            18271
          ],
          "shape": [
            3
          ],
          "dtype": "datetime64[D]",
          "unit": "D"
        },
        "b": {
          "data": [
            2,
            -9223372036854775808,
            -3
          ],
          "shape": [
            3
          ],
          "dtype": "timedelta64[D]",
          "unit": "D"
        }
      },
      "expected": {
        "data": [
          18264,
          -9223372036854775808,
          18268
        ],
        "shape": [
          3
        ],
        "dtype": "datetime64[D]",
        "unit": "D"
      },
      "tolerance_ulps": 0
    }
  ]
}
