        "outer": {
          "divide": "warn",
          "over": "warn",
          "under": "ignore",
          "invalid": "warn"
        }
      },
      "tolerance_ulps": 0
    },
    {
      "name": "policy_meanings",
      "inputs": {},
      "expected": {
        "warn": "record",
        "ignore": "drop",
        "raise": "defer_error"
      },
      "tolerance_ulps": 0
    }
  ]
}
