            0.0
          ],
          "shape": [
            5
          ],
          "dtype": "float64"
        },
        "integral": {
          "data": [
            0.0,
            -0.0,
            1.0,
            -2.0,
            3.0
          ],
          "shape": [
            5
          ],
          "dtype": "float64"
        }
      },
      "tolerance_ulps": 0
    },
    {
      "name": "special",
      "inputs": {
        "x": {
          "data": [
            "NaN",
            "Inf",
            "-Inf"
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "fractional": {
          "data": [
            "NaN",
            0.0,
            -0.0
          ],
          "shape": [
            3
          ],
