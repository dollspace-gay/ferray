{
  "numpy_version": "2.4.5",
  "fixture_schema_version": 2,
  "function": "numpy.nextafter",
  "ferray_function": "ferray_ufunc::nextafter",
  "test_cases": [
    {
      "name": "toward_positive",
      "inputs": {
        "a": {
          "data": [
            0.0,
            1.0,
            -1.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            1.0,
            2.0,
            0.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          5e-324,
          1.0000000000000002,
          -0.9999999999999999
        ],
        "shape": [
          3
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "toward_negative",
      "inputs": {
        "a": {
          "data": [
            0.0,
            1.0,
            -1.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            -1.0,
            0.0,
            -2.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          -5e-324,
          0.9999999999999999,
          -1.0000000000000002
        ],
        "shape": [
          3
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "equal_and_nan",
      "inputs": {
        "a": {
          "data": [
            1.0,
            "NaN",
            2.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            1.0,
            0.0,
            "NaN"
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          1.0,
          "NaN",
          "NaN"
        ],
        "shape": [
          3
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "broadcast_2d",
      "inputs": {
        "a": {
          "data": [
            0.0,
            1.0
          ],
          "shape": [
            2,
            1
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            1.0,
            -1.0
          ],
          "shape": [
            1,
            2
          ],
          "dtype": "float64"
        }
      },
      "expected": {
        "data": [
          5e-324,
          -5e-324,
          1.0,
          0.9999999999999999
        ],
        "shape": [
          2,
          2
        ],
        "dtype": "float64"
      },
      "tolerance_ulps": 0
    }
  ]
}
