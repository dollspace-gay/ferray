{
  "numpy_version": "2.4.5",
  "fixture_schema_version": 2,
  "function": "numpy.isclose",
  "ferray_function": "ferray_ufunc::isclose",
  "test_cases": [
    {
      "name": "standard",
      "inputs": {
        "a": {
          "data": [
            1.0,
            2.0,
            3.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            1.000000001,
            2.1,
            3.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "rtol": 1e-05,
        "atol": 1e-08,
        "equal_nan": false
      },
      "expected": {
        "data": [
          true,
          false,
          true
        ],
        "shape": [
          3
        ],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "equal_nan_false",
      "inputs": {
        "a": {
          "data": [
            "NaN",
            1.0
          ],
          "shape": [
            2
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            "NaN",
            1.0
          ],
          "shape": [
            2
          ],
          "dtype": "float64"
        },
        "rtol": 1e-05,
        "atol": 1e-08,
        "equal_nan": false
      },
      "expected": {
        "data": [
          false,
          true
        ],
        "shape": [
          2
        ],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "equal_nan_true",
      "inputs": {
        "a": {
          "data": [
            "NaN",
            1.0
          ],
          "shape": [
            2
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            "NaN",
            1.0
          ],
          "shape": [
            2
          ],
          "dtype": "float64"
        },
        "rtol": 1e-05,
        "atol": 1e-08,
        "equal_nan": true
      },
      "expected": {
        "data": [
          true,
          true
        ],
        "shape": [
          2
        ],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "matching_infinities",
      "inputs": {
        "a": {
          "data": [
            "Inf",
            "-Inf",
            1.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            "Inf",
            "-Inf",
            "Inf"
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "rtol": 1e-05,
        "atol": 1e-08,
        "equal_nan": false
      },
      "expected": {
        "data": [
          true,
          true,
          false
        ],
        "shape": [
          3
        ],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "broadcast_2d",
      "inputs": {
        "a": {
          "data": [
            1.0,
            2.0,
            3.0,
            1.0,
            2.01,
            3.0
          ],
          "shape": [
            2,
            3
          ],
          "dtype": "float64"
        },
        "b": {
          "data": [
            1.0,
            2.0,
            4.0
          ],
          "shape": [
            3
          ],
          "dtype": "float64"
        },
        "rtol": 0.01,
        "atol": 1e-08,
        "equal_nan": false
      },
      "expected": {
        "data": [
          true,
          true,
          false,
          true,
          true,
          false
        ],
        "shape": [
          2,
          3
        ],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    }
  ]
}
