{
  "function": "regex match (anchored)",
  "ferray_function": "ferray_strings::match_",
  "test_cases": [
    {
      "name": "digit_pattern",
      "inputs": {
        "x": {
          "data": ["abc123", "noNumbers", "456"],
          "shape": [3],
          "dtype": "str"
        },
        "pattern": "\\d+"
      },
      "expected": {
        "data": [true, false, true],
        "shape": [3],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    },
    {
      "name": "anchored_full_match",
      "inputs": {
        "x": {
          "data": ["abc", "abcdef", "xabc"],
          "shape": [3],
          "dtype": "str"
        },
        "pattern": "^abc$"
      },
      "expected": {
        "data": [true, false, false],
        "shape": [3],
        "dtype": "bool"
      },
      "tolerance_ulps": 0
    }
  ]
}
